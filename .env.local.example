# Copy to .env.local and fill in. Never commit .env.local.

# Which model provider the API routes use: openrouter | deepseek | anthropic | mock
LLM_PROVIDER=deepseek

# Key for openrouter/deepseek providers
LLM_API_KEY=

# Model slug for openrouter/deepseek.
#   OpenRouter (Claude): anthropic/claude-sonnet-4.6  (check exact slug at openrouter.ai/models)
#   DeepSeek:            deepseek-chat
LLM_MODEL=anthropic/claude-sonnet-4.6

# Only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- v3.2 extraction fallbacks (both OPTIONAL — leave unset and the app
# --- still works; the fallbacks are simply skipped) ---

# supadata.ai — YouTube transcripts when watch-page scraping is blocked
# (always the case on Vercel's datacenter IPs). Free tier is enough.
SUPADATA_API_KEY=

# r.jina.ai — article-text fallback. Works keyless (rate-limited); a free
# key raises the limits. v3.5: the same key also powers article SEARCH
# (s.jina.ai) in the "Find sources" panel.
JINA_API_KEY=

# --- v3.5 source discovery (OPTIONAL — without it video search falls back
# --- to scraping YouTube's results page, which is flaky from Vercel) ---

# YouTube Data API v3 key — free (10k units/day ≈ 100 searches), no billing
# account needed: console.cloud.google.com → enable "YouTube Data API v3"
# → Credentials → Create API key.
YOUTUBE_API_KEY=
